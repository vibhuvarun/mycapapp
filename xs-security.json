{
  "xsappname": "mycapapp",
  "tenant-mode": "dedicated",
  "scopes": [
    {
      "name": "$XSAPPNAME.Display",
      "description": "Display "
    },
    {
      "name": "$XSAPPNAME.Edit",
      "description": "Edit "
    },
    {
      "name": "$XSAPPNAME.Boost",
      "description": "Boost"
    }
  ],
  "attributes": [
    {
      "name": "country",
      "description": "Country attribute"
    },
    {
      "name": "city",
      "description": "City attribute"
    }
  ],
  "role-templates": [
    {
      "name": "Viewer",
      "description": "Viewer role",
      "scope-references": [
        "$XSAPPNAME.Display"
      ]
    },
    {
      "name": "User",
      "description": "Normal user role",
      "scope-references": [
        "$XSAPPNAME.Edit"
      ]
    },
    {
      "name": "Admin",
      "description": "Administrator role",
      "scope-references": [
        "$XSAPPNAME.Display",
        "$XSAPPNAME.Edit",
        "$XSAPPNAME.Boost"
      ],
      "attribute-references": [
        {
          "name": "country",
          "default-value": [
            "india"
          ]
        },
        {
          "name": "city",
          "default-value": [
            "*"
          ]
        }
      ],
      "oauth2-configuration": {
        "token-validity": 3600,
        "redirect-uris": [
          "https://*.cfapps.us10-001.hana.ondemand.com/login/callback/"
        ]
      },
      "xsenableasyncservice": "true"
    }
  ]
}
